# Email Configuration
# Copy this file to .env.local and fill in your values

# Gmail Configuration
GMAIL_USER=titleistteam@gmail.com
GMAIL_APP_PASSWORD=agtdtxhcagkmvjoc

# API Secret for email endpoint authentication
EMAIL_API_SECRET=your-random-secret-key-here

# SendGrid (Alternative)
# SENDGRID_API_KEY=your-sendgrid-api-key

# AWS SES (Alternative)
# AWS_REGION=us-east-1
# AWS_ACCESS_KEY_ID=your-access-key
# AWS_SECRET_ACCESS_KEY=your-secret-key

# Email Service URL (if using external service)
EMAIL_SERVICE_URL=https://your-domain.com/api/send-email

# Logo URL (public URL for email template)
EMAIL_LOGO_URL=https://your-domain.com/full-color-mark.png

# Rate Limiting
EMAIL_RATE_LIMIT_PER_HOUR=100
EMAIL_RATE_LIMIT_PER_DAY=500

# Email Settings
EMAIL_FROM_NAME=Golf Score Team
EMAIL_FROM_ADDRESS=titleistteam@gmail.com
EMAIL_REPLY_TO=titleistteam@gmail.com

# Development Mode (set to 'true' to log emails instead of sending)
EMAIL_DEV_MODE=false
